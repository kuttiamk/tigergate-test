#!/usr/bin/env bash
# =============================================================================
# pre-commit – TigerGate CNAPP Test Suite: Pre-Commit Hook
# =============================================================================
# INSTALL: cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# OR:      make install-hooks
#
# CHECKS RUN ON EVERY COMMIT:
#   1. Secret detection (Gitleaks pattern matching)
#   2. Terraform HCL syntax validation
#   3. Python syntax validation (py_compile)
#   4. Node.js syntax check (node --check)
#   5. YAML schema validation
# =============================================================================

set -eo pipefail
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'

echo -e "${YELLOW}▶ Running TigerGate pre-commit checks...${NC}"

ERRORS=0

# ── 1. Secret Pattern Detection ──────────────────────────────────────────────
echo "  [1/5] Scanning for accidentally committed secrets..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
SECRET_PATTERNS='AKIA[0-9A-Z]{16}|sk_live_[a-zA-Z0-9]{24,}|ghp_[a-zA-Z0-9]{36}|(?i)password\s*=\s*["\x27][^"\x27]{4,}'

for file in $STAGED_FILES; do
  if git show ":$file" | grep -Eq "$SECRET_PATTERNS" 2>/dev/null; then
    echo -e "    ${RED}✗ Potential secret in: $file${NC}"
    echo -e "    ${YELLOW}NOTE: This suite includes intentional test secrets — verify this is expected.${NC}"
    # Only warn, don't block (test suite intentionally has secrets)
  fi
done
echo -e "    ${GREEN}✓ Secret scan complete${NC}"

# ── 2. Terraform Syntax Validation ───────────────────────────────────────────
echo "  [2/5] Validating Terraform HCL syntax..."
if command -v terraform &>/dev/null; then
  for dir in cspm ciem attack_paths ai_spm dspm; do
    if [ -d "$dir" ]; then
      cd "$dir"
      terraform validate -no-color 2>&1 | grep -E "Success|Error" || true
      cd ..
    fi
  done
  echo -e "    ${GREEN}✓ Terraform validation complete${NC}"
else
  echo -e "    ${YELLOW}⚠ terraform not installed — skipping HCL validation${NC}"
fi

# ── 3. Python Syntax Check ───────────────────────────────────────────────────
echo "  [3/5] Checking Python syntax..."
PYTHON_FILES=$(echo "$STAGED_FILES" | grep '\.py$' || true)
for f in $PYTHON_FILES; do
  if [ -f "$f" ]; then
    python3 -m py_compile "$f" && echo -e "    ${GREEN}✓ $f${NC}" || { echo -e "    ${RED}✗ $f${NC}"; ERRORS=$((ERRORS+1)); }
  fi
done

# ── 4. Node.js Syntax Check ──────────────────────────────────────────────────
echo "  [4/5] Checking JavaScript syntax..."
JS_FILES=$(echo "$STAGED_FILES" | grep '\.js$' || true)
for f in $JS_FILES; do
  if [ -f "$f" ]; then
    node --check "$f" 2>&1 && echo -e "    ${GREEN}✓ $f${NC}" || { echo -e "    ${RED}✗ $f${NC}"; ERRORS=$((ERRORS+1)); }
  fi
done

# ── 5. YAML Validation ───────────────────────────────────────────────────────
echo "  [5/5] Validating YAML files..."
YAML_FILES=$(echo "$STAGED_FILES" | grep -E '\.(yml|yaml)$' || true)
for f in $YAML_FILES; do
  if [ -f "$f" ]; then
    python3 -c "import yaml; yaml.safe_load(open('$f'))" 2>&1 && \
      echo -e "    ${GREEN}✓ $f${NC}" || \
      { echo -e "    ${RED}✗ $f${NC}"; ERRORS=$((ERRORS+1)); }
  fi
done

echo ""
if [ "$ERRORS" -gt 0 ]; then
  echo -e "${RED}✗ Pre-commit failed: $ERRORS error(s) found. Fix and try again.${NC}"
  exit 1
fi
echo -e "${GREEN}✓ All pre-commit checks passed!${NC}"
